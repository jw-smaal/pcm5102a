menu "Waveform Generator Options"

config WAVEFORM_FREQUENCY
	int "Waveform frequency (Hz)"
	default 1000
	help
	  The target frequency of the generated waveform in Hz.

config AUDIO_SAMPLE_RATE
	int "Sample Rate (Hz)"
	default 192000
	help
	  How many times per second the audio value is updated. (Recommended: 192000 for low aliasing)

config AUDIO_BIT_WIDTH
	int "Sample Bit Width"
	default 16
	range 16 32
	help
	  The bit width of each audio sample (16 or 32).

endmenu

source "Kconfig.zephyr"
